{
  "name": "@ninna-ui/core",
  "version": "0.4.1",
  "description": "Design tokens, Tailwind CSS v4 class mappings, and 5 oklch CSS theme presets with automatic dark mode for Ninna UI",
  "license": "MIT",
  "author": "Ninna-UI Team",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ninna-ui/ninna-ui.git",
    "directory": "packages/core"
  },
  "homepage": "https://ninna-ui.dev/getting-started/theming",
  "bugs": {
    "url": "https://github.com/ninna-ui/ninna-ui/issues"
  },
  "keywords": [
    "ninna-ui",
    "design-system",
    "design-tokens",
    "tailwindcss",
    "tailwindcss-v4",
    "theme",
    "oklch",
    "css-variables",
    "dark-mode",
    "color-tokens",
    "react"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./theme/*.css": "./dist/theme/*.css",
    "./package.json": "./package.json"
  },
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "scripts": {
    "generate-safelist": "node scripts/generate-safelist.mjs",
    "build": "node scripts/generate-safelist.mjs && tsup && node -e \"const fs=require('fs');const p=require('path');function cpCss(s,d){fs.mkdirSync(d,{recursive:true});for(const f of fs.readdirSync(s,{withFileTypes:true})){const sp=p.join(s,f.name),dp=p.join(d,f.name);f.isDirectory()?cpCss(sp,dp):f.name.endsWith('.css')&&fs.copyFileSync(sp,dp)}}cpCss('src/theme','dist/theme')\"",
    "verify-classes": "node scripts/verify-classes.mjs",
    "dev": "tsup --watch",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"src/**/*.ts\"",
    "clean": "rimraf dist"
  },
  "peerDependencies": {
    "tailwindcss": ">=4.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependenciesMeta": {
    "tailwindcss": {
      "optional": true
    }
  },
  "devDependencies": {
    "@ninna-ui/tsconfig": "workspace:*",
    "@ninna-ui/test-config": "workspace:*",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^4.0.0"
  }
}