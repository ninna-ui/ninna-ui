{
  "name": "@ninna-ui/cli",
  "version": "0.5.0",
  "description": "CLI tool for scaffolding Ninna UI projects - Vite + React, Next.js 15, React Router v7 templates with 5 theme presets. Tailwind CSS v4.",
  "license": "MIT",
  "author": "Ninna-UI Team",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ninna-ui/ninna-ui.git",
    "directory": "packages/cli"
  },
  "homepage": "https://ninna-ui.dev/getting-started/installation",
  "bugs": {
    "url": "https://github.com/ninna-ui/ninna-ui/issues"
  },
  "keywords": [
    "ninna-ui",
    "cli",
    "scaffolding",
    "react",
    "nextjs",
    "vite",
    "react-router",
    "starter-template",
    "project-generator",
    "tailwindcss",
    "tailwindcss-v4"
  ],
  "type": "module",
  "bin": {
    "ninna-ui": "./dist/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "templates"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup src/index.ts --format esm --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"src/**/*.ts\"",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "commander": "^14.0.3",
    "prompts": "^2.4.2",
    "picocolors": "^1.1.0",
    "fs-extra": "^11.3.4"
  },
  "devDependencies": {
    "@ninna-ui/tsconfig": "workspace:*",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^22.14.0",
    "@types/prompts": "^2.4.9",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  }
}