{
  "name": "@ninna-ui/primitives",
  "version": "0.4.1",
  "description": "14 primitive React UI components for Ninna UI - Button, Badge, Avatar, Text, Heading, Link, Code, Kbd, Divider, and more. Accessible, themeable, Tailwind CSS v4.",
  "license": "MIT",
  "author": "Ninna-UI Team",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ninna-ui/ninna-ui.git",
    "directory": "packages/primitives"
  },
  "homepage": "https://ninna-ui.dev/primitives",
  "bugs": {
    "url": "https://github.com/ninna-ui/ninna-ui/issues"
  },
  "keywords": [
    "ninna-ui",
    "react",
    "components",
    "button",
    "badge",
    "avatar",
    "heading",
    "text",
    "link",
    "divider",
    "code",
    "kbd",
    "typography",
    "accessible",
    "data-slot",
    "tailwindcss",
    "tailwindcss-v4",
    "ui"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@ninna-ui/core": "workspace:*",
    "@ninna-ui/utils": "workspace:*",
    "class-variance-authority": "^0.7.1"
  },
  "peerDependencies": {
    "react": ">=19.0.0",
    "react-dom": ">=19.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@ninna-ui/tsconfig": "workspace:*",
    "@ninna-ui/test-config": "workspace:*",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}