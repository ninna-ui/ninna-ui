{
  "name": "@ninna-ui/code-block",
  "version": "0.3.3",
  "description": "Syntax-highlighted code block React component for Ninna UI — copy-to-clipboard, line numbers, automatic dark mode, zero external dependencies. Tailwind CSS v4.",
  "license": "MIT",
  "author": "Ninna-UI Team",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ninna-ui/ninna-ui.git",
    "directory": "packages/code-block"
  },
  "homepage": "https://ninna-ui.dev/code-block",
  "bugs": {
    "url": "https://github.com/ninna-ui/ninna-ui/issues"
  },
  "keywords": [
    "ninna-ui",
    "react",
    "code-block",
    "syntax-highlighting",
    "copy-to-clipboard",
    "line-numbers",
    "dark-mode",
    "accessible",
    "data-slot",
    "tailwindcss",
    "tailwindcss-v4",
    "ui"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./styles": "./src/code-block/code-block.css",
    "./package.json": "./package.json"
  },
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "src/code-block/code-block.css"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@ninna-ui/core": "workspace:*",
    "@ninna-ui/utils": "workspace:*",
    "class-variance-authority": "^0.7.1"
  },
  "peerDependencies": {
    "react": ">=19.0.0",
    "react-dom": ">=19.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@ninna-ui/tsconfig": "workspace:*",
    "@ninna-ui/test-config": "workspace:*",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^4.0.0"
  }
}