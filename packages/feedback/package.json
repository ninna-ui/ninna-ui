{
  "name": "@ninna-ui/feedback",
  "version": "0.1.0",
  "description": "Feedback UI components for Ninna-UI - Alert, Toast, Progress, Loading",
  "license": "MIT",
  "author": "Ninna-UI Team",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ninna-ui/ninna-ui.git",
    "directory": "packages/feedback"
  },
  "homepage": "https://ninna-ui.dev/feedback",
  "bugs": {
    "url": "https://github.com/ninna-ui/ninna-ui/issues"
  },
  "keywords": [
    "ninna-ui",
    "react",
    "alert",
    "toast",
    "progress",
    "loading",
    "feedback",
    "ui"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
