{
  "name": "@ninna-ui/layout",
  "version": "0.5.0",
  "description": "10 layout React components for Ninna UI - Box, Stack, Flex, Grid, Container, Center, Wrap, SimpleGrid, AspectRatio, Separator. Responsive, Tailwind CSS v4.",
  "license": "MIT",
  "author": "Ninna-UI Team",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ninna-ui/ninna-ui.git",
    "directory": "packages/layout"
  },
  "homepage": "https://ninna-ui.dev/layout",
  "bugs": {
    "url": "https://github.com/ninna-ui/ninna-ui/issues"
  },
  "keywords": [
    "ninna-ui",
    "react",
    "layout",
    "stack",
    "flex",
    "grid",
    "box",
    "container",
    "center",
    "wrap",
    "simple-grid",
    "aspect-ratio",
    "separator",
    "responsive",
    "data-slot",
    "tailwindcss",
    "tailwindcss-v4",
    "ui"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@ninna-ui/core": "workspace:*",
    "@ninna-ui/utils": "workspace:*",
    "class-variance-authority": "^0.7.1"
  },
  "peerDependencies": {
    "react": ">=19.0.0",
    "react-dom": ">=19.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@ninna-ui/tsconfig": "workspace:*",
    "@ninna-ui/test-config": "workspace:*",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.4"
  }
}
