{
  "name": "ninna-ui",
  "version": "0.0.0",
  "private": true,
  "description": "A React-first, framework-agnostic UI system with design tokens, primitives, and layouts",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ninna-ui/ninna-ui.git"
  },
  "type": "module",
  "license": "MIT",
  "author": "Ninna-UI Team",
  "workspaces": [
    "packages/*",
    "apps/*",
    "tooling/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint typecheck",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\"",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "turbo run build && changeset publish",
    "check-exports": "publint packages/core && publint packages/utils && publint packages/react-internal && publint packages/primitives && publint packages/feedback && publint packages/layout && publint packages/forms && publint packages/overlays && publint packages/navigation && publint packages/data-display && publint packages/code-block && publint packages/cli",
    "check-pack": "node scripts/check-pack.js",
    "check-internal-deps": "node scripts/check-internal-deps.js"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.2",
    "@changesets/changelog-github": "^0.2.0",
    "@changesets/cli": "^2.29.8",
    "@ninna-ui/eslint-config": "workspace:*",
    "@ninna-ui/test-config": "workspace:*",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "eslint": "^9.39.4",
    "jsdom": "^29.0.0",
    "prettier": "^3.8.0",
    "publint": "^0.3.18",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "rimraf": "^6.1.3",
    "turbo": "^2.8.20",
    "typescript": "^5.9.3",
    "undici": "^7.24.4",
    "vitest": "^4.1.0",
    "vitest-axe": "1.0.0-pre.5"
  },
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  }
}
